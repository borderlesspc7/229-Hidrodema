# Copie para .env na raiz do projeto.
# Valores: Firebase Console → Configurações do projeto → Suas apps → SDK setup (npm).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Opcional: sincronização da base de vendedores (Gestão de vendedores).
# VITE_SELLER_API_BASE_URL=https://sua-api.com/v1
# VITE_SELLER_API_TOKEN=
