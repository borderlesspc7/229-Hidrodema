# Copie para .env na raiz do projeto.
# Valores: Firebase Console → Configurações do projeto → Suas apps → SDK setup (npm).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_ID=(default)

# Módulos do menu (true/false). Omitir = usar valor por defeito no código.
# VITE_FEATURE_MEETING=false
# VITE_FEATURE_MARKETING=false
# VITE_FEATURE_GESTAO_VENDEDORES=true

# Opcional: erros em produção (https://sentry.io) — só ativa se definido.
# VITE_SENTRY_DSN=

# Opcional: sincronização da base de vendedores (Gestão de vendedores).
# A sincronização via API externa agora roda nas Cloud Functions (server-side).
# Configure no ambiente das Functions (NÃO no .env do frontend):
# - SELLER_API_BASE_URL=https://sua-api.com/v1
# - SELLER_API_TOKEN=... (opcional, Bearer)
